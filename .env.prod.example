NODE_ENV=production
LOG_LEVEL=log

# Database
POSTGRES_USER=tvwatch
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=tvwatch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Required for Prisma CLI (db push, migrate). URL-encode special chars in password:
#   + → %2B, / → %2F, = → %3D, @ → %40, # → %23
DATABASE_URL=postgresql://tvwatch:CHANGE_ME_STRONG_PASSWORD@postgres:5432/tvwatch?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
# Optional: set REDIS_URL instead of host/port if you prefer URL format
# REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# API
API_PORT=4000
API_BASE_URL=https://api.tvwatchtime.org
CORS_ORIGINS=https://admin.tvwatchtime.org

# Auth
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BOOTSTRAP_SUPER_ADMIN_EMAIL=you@example.com

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=tvwatch
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=tvwatch-media
S3_BUCKET_COMMENT_IMAGES=tvwatch-comment-images
S3_BUCKET_TEMP_UPLOADS=tvwatch-temp-uploads
S3_ACCESS_KEY_ID=tvwatch
S3_SECRET_ACCESS_KEY=CHANGE_ME_STRONG_MINIO_PASSWORD

# Encryption
ENCRYPTION_MASTER_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# TMDb
TMDB_API_KEY=
TMDB_LANGUAGE=en-US
TMDB_RPS=40

# TVmaze
TVMAZE_ENABLED=true
TVMAZE_API_KEY=

# TVDB (optional — adds more shows to search, larger database)
TVDB_API_KEY=
TVDB_RPS=10

# OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Push
EXPO_ACCESS_TOKEN=
PUSH_MODE=expo
PUSH_RELAY_ENABLED=true
PUSH_RELAY_RATE_LIMIT=10
PUSH_RELAY_RATE_WINDOW_MINUTES=10

# OpenAI Moderation (leave blank to skip moderation)
OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Email (for data deletion requests) — leave blank to disable email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tvwatchtime.org

# Limits
IMPORT_DAILY_LIMIT=10
MAX_PUSH_NOTIFICATIONS_PER_USER_PER_DAY=3
MAX_COMMENT_IMAGE_UPLOAD_MB=5
COMMENT_IMAGE_UPLOADS_PER_USER_PER_DAY=20

# Performance tuning (defaults are safe for small servers — increase for larger hardware)

# Database connections (Prisma pool size)
DATABASE_CONNECTION_LIMIT=20

# Postgres tuning (set shared_buffers to ~25% of RAM)
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=4MB

# External API rate limits (0 = unlimited, automatic backoff on 429)
TMDB_RPS=0
TVDB_RPS=0

# Background workers
IMPORT_WORKER_CONCURRENCY=2
COMMENT_IMAGE_WORKER_CONCURRENCY=2