###############################################################################
# TVWatchTime environment configuration
# Copy to .env and fill in. Never commit .env.
###############################################################################

# ---- Core ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- API ----
API_PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://192.168.0.10:8081

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://tvwatch:tvwatch@localhost:5432/tvwatch?schema=public

# ---- Redis (cache + BullMQ queues) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=change-me-a-very-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# OAuth providers (leave blank to disable; dev email/password works regardless)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_SHARED_SECRET=

# ---- Mobile / Push ----
# Expo project + push
EXPO_ACCESS_TOKEN=
# Firebase Admin (Android FCM + APNs via FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# APNs directly (optional if using FCM)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_PATH=

# ---- Storage (S3-compatible) ----
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=tvwatch-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ---- Third-party metadata ----
# Provide these to enable LIVE metadata; blank => seeded mock data is used.
TMDB_API_KEY=
TMDB_LANGUAGE=en-US
# Global TMDb rate ceiling (requests/second) across the whole API process.
TMDB_RPS=40
TVMAZE_ENABLED=true
TVMAZE_API_KEY=
# Season rating chart source: false = app users' ratings only (unrated episode = 0);
# true = also use TMDb ratings for episodes with no user votes yet.
USE_API_FOR_EPISODES_CHART=false
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# ---- TVDB v4 (resilience config) ----
TVDB_ENABLED=true
TVDB_API_KEY=
TVDB_PIN=
TVDB_REQUESTS_PER_SECOND=2
TVDB_REQUESTS_PER_MINUTE=60
TVDB_CONCURRENCY=2
TVDB_TIMEOUT_MS=10000
TVDB_MAX_RETRIES=5
TVDB_BACKOFF_BASE_MS=500
TVDB_BACKOFF_MAX_MS=30000
TVDB_CACHE_TTL_SECONDS=86400
TVDB_NEGATIVE_CACHE_TTL_SECONDS=3600

# ---- Kitsu (Option B: internal gateway/cache to the public Kitsu catalogue) ----
KITSU_ENABLED=true
KITSU_BASE_URL=https://kitsu.app/api/edge
KITSU_API_MODE=jsonapi        # verify against current Kitsu contract at deploy
KITSU_REQUESTS_PER_SECOND=3
KITSU_REQUESTS_PER_MINUTE=60
KITSU_CONCURRENCY=2
KITSU_TIMEOUT_MS=10000
KITSU_MAX_RETRIES=5
KITSU_BACKOFF_BASE_MS=500
KITSU_BACKOFF_MAX_MS=30000
KITSU_CACHE_TTL_SECONDS=86400

# ---- Jikan (optional self-host; retrieval provider for MyAnimeList) ----
# JIKAN_BASE_URL points at the self-host instance (docker compose --profile metadata);
# the public API is used as a fallback when local Jikan is unavailable/not ready.
JIKAN_ENABLED=true
JIKAN_BASE_URL=http://jikan:8080/v4
JIKAN_PUBLIC_FALLBACK=true
JIKAN_REQUESTS_PER_SECOND=3
JIKAN_REQUESTS_PER_MINUTE=60
JIKAN_CONCURRENCY=2
JIKAN_TIMEOUT_MS=15000
JIKAN_MAX_RETRIES=5
JIKAN_BACKOFF_BASE_MS=750
JIKAN_BACKOFF_MAX_MS=60000
JIKAN_CACHE_TTL_SECONDS=86400


# ---- Background jobs ----
METADATA_REFRESH_CRON=0 3 * * *
NOTIFICATIONS_DISPATCH_CRON=*/5 * * * *
# Max imports per user per day
IMPORT_DAILY_LIMIT=3

# ---- Comment images ----
OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest
# Encryption master key (32+ chars, hex-safe). CHANGE IN PROD.
ENCRYPTION_MASTER_KEY=dev-master-key-change-in-prod-32bytes!
# S3 (use MinIO for dev: endpoint http://localhost:9000)
S3_REGION=us-east-1
S3_BUCKET_COMMENT_IMAGES=tvwatch-comment-images
S3_BUCKET_TEMP_UPLOADS=tvwatch-temp-uploads
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=tvwatch
S3_SECRET_ACCESS_KEY=tvwatch123
# Limits
MAX_COMMENT_IMAGE_UPLOAD_MB=5
MAX_COMMENT_IMAGE_HARD_LIMIT_MB=20
MAX_COMMENT_IMAGE_PIXELS=36000000
COMMENT_IMAGE_MAX_LONG_EDGE=1600
COMMENT_IMAGE_WEBP_QUALITY=95
COMMENT_THUMBNAIL_MAX_LONG_EDGE=480
COMMENT_THUMBNAIL_WEBP_QUALITY=85
COMMENT_IMAGE_UPLOADS_PER_USER_PER_DAY=20
COMMENT_IMAGE_WORKER_CONCURRENCY=2

# Notification limits
MAX_PUSH_NOTIFICATIONS_PER_USER_PER_DAY=3

# ---- Push relay (for self-hosted backends) ----
# If this is the PUBLIC instance: enable relay so self-hosted users can push
PUSH_RELAY_ENABLED=true
PUSH_RELAY_RATE_LIMIT=10
PUSH_RELAY_RATE_WINDOW_MINUTES=10
# If this is a SELF-HOSTED instance without Expo token:
PUSH_MODE=expo          # expo (has token) | relay (use public server) | none
PUSH_RELAY_URL=         # e.g. https://api.tvwatchtime.org/api

# Note: GIPHY API keys for the mobile GIF picker live in apps/mobile/app.json
# under expo.extra (giphyApiKeyAndroid|Ios|Web), not here. See docs/ENVIRONMENT.md.
